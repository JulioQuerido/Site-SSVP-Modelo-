PORT=3001
NODE_ENV=development

# SQLite (uso local / VPS). Ignorado se DATABASE_URL estiver definida.
DATABASE_PATH=./data/ssvp_portal.db

# Postgres (produção serverless / Vercel). Se definida, o backend usa
# automaticamente Postgres (via Knex + pg) em vez do SQLite.
# Ex: string de conexão pooled do Neon (https://neon.tech), que é o Postgres
# oferecido na aba "Storage" do painel do Vercel.
# DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require
# DATABASE_SSL=true

JWT_SECRET=troque-este-segredo-por-algo-seguro
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh-por-outro-valor-seguro
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contato@ssvpbrasil.org.br
SMTP_PASS=sua-senha-de-app
EMAIL_FROM="SSVP Portal <contato@ssvpbrasil.org.br>"
EMAIL_OUVIDORIA=ouvidoria@ssvpbrasil.org.br

# Frontend
CORS_ORIGIN=http://localhost:5173

# Upload
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./public/uploads

# Vercel Blob (produção serverless). Se definida, os PDFs são enviados para o
# Vercel Blob em vez do disco local. Gerada automaticamente ao conectar um
# "Blob store" na aba Storage do projeto no Vercel.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# IPEA / Mapa OSC
IPEA_FICHA_URL=https://mapaosc.ipea.gov.br/detalhar/844520
IPEA_CACHE_TTL_HOURS=24
